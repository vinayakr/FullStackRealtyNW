# Copy to .env.prod and fill in values before deploying.
APP_ENV=production
AWS_REGION=us-west-2

# AWS Secrets Manager secret names (not the actual secret values)
ANTHROPIC_API_KEY_SECRET=prod/fullstackrealtynw/anthropic-api-key
RAPIDAPI_KEY_SECRET=prod/fullstackrealtynw/rapidapi-key
DATABASE_PASSWORD_SECRET=prod/fullstackrealtynw/db-password
DATABASE_USER=realty_user

# SumoLogic HTTP Collector URL (Manage Data → Collection → Add Source)
SUMO_LOGIC_URL=https://collectors.sumologic.com/receiver/v1/http/YOUR_TOKEN_HERE
