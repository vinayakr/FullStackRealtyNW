# ── Production environment — copy to .env.prod and fill in values ─────────────
# Secrets are fetched from AWS Secrets Manager at startup.
APP_ENV=production
AWS_REGION=us-west-2

# AWS Secrets Manager secret names (not the actual secret values)
ANTHROPIC_API_KEY_SECRET=prod/fullstackrealtynw/anthropic-api-key
DATABASE_PASSWORD_SECRET=prod/fullstackrealtynw/db-password
SMTP_PASSWORD_SECRET=prod/fullstackrealtynw/smtp-password

# Database — must match the value stored in DATABASE_PASSWORD_SECRET (used to init Postgres)
DATABASE_PASSWORD=
DATABASE_USER=realty_user

# Gmail SMTP sender and lead notification recipient
SMTP_USER=vinny@fullstackrealtynw.com
NOTIFY_EMAIL=vinny@fullstackrealtynw.com

# SumoLogic HTTP Collector URL (Manage Data → Collection → Add Source)
SUMO_LOGIC_URL=
