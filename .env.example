# ── Local development — set values directly ───────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DATABASE_PASSWORD=realty_password

# ── Logging / SumoLogic ────────────────────────────────────────────────────────
# HTTP Collector URL from SumoLogic (Sources > Add Source > HTTP Logs & Metrics)
SUMO_LOGIC_URL=https://collectors.sumologic.com/receiver/v1/http/YOUR_TOKEN_HERE
APP_ENV=production

# ── Production — reference AWS Secrets Manager secret names instead ───────────
# Set FOO_SECRET to an AWS Secrets Manager secret name or ARN.
# The app will fetch the real value from AWS at startup.
# Direct FOO values take precedence if both are set.
#
# AWS_REGION=us-west-2
# ANTHROPIC_API_KEY_SECRET=prod/fullstackrealtynw/anthropic-api-key
# DATABASE_PASSWORD_SECRET=prod/fullstackrealtynw/db-password
#
# AWS credentials are picked up from the default provider chain:
#   - AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars
#   - ECS task role / EC2 instance profile (recommended for production)
#   - ~/.aws/credentials
